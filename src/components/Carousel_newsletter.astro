---
import "keen-slider/keen-slider.min.css";
const { data = [], isImage = true } = Astro.props;
---

    <div id="newsletter-carousel" class="keen-slider">
    {data.map((item, index) => (
<div class="keen-slider__slide bg-white text-black shadow-xl p-4 font-bold rounded-lg mb-12 flex flex-col items-center text-center w-auto" >
    <a href={item.readMoreHref} target="_blank" rel="noopener noreferrer">
    <h3 class="text-lg font-semibold mb-2">{item.title}</h3>

    {isImage && (
        <img 
            src={'/assets/newsLetter_pics/' + item.imagePath} 
            onerror="this.src='/assets/newsLetter_pics/pic_def.png';" 
            alt={item.title} 
            class="rounded-md object-cover w-36 h-48"
        />
    )}
</a>
</div>
    ))}
</div>


<script>
  import KeenSlider from "keen-slider";

  document.addEventListener("DOMContentLoaded", () => {
    const slider = new KeenSlider("#newsletter-carousel", {
      loop: true,
      mode: "free-snap",   
      renderMode: "performance",

      defaultAnimation:{
        duration: 1000,
      },

      slides: {
        perView: 1.2,
        spacing: 20,
      },

      breakpoints: {
        "(min-width: 768px)": {
          slides: {
            perView: 2.2,
            spacing: 20,
          },
        },
        "(min-width: 1024px)": {
          slides: {
            perView: 5.2,
            spacing: 20,
          },
        },
      },

      created(s) {
        let timeout;
        let mouseOver = false;

        function clearNextTimeout() {
          clearTimeout(timeout);
        }

        function nextTimeout() {
          clearTimeout(timeout);
          if (mouseOver) return;
          timeout = setTimeout(() => {
            s.next();
          }, 1500);
        }

        // ✅ Start auto-rotation immediately — no nested s.on("created") wrapper
        nextTimeout();

        s.container.addEventListener("mouseover", () => {
          mouseOver = true;
          clearNextTimeout();
        });

        s.container.addEventListener("mouseout", () => {
          mouseOver = false;
          nextTimeout();
        });

        s.on("dragStarted", clearNextTimeout);
        s.on("animationEnded", nextTimeout);
        s.on("updated", nextTimeout);
      },
    });
  });
</script>